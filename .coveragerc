[run]
branch = True
source = dbldatagen
omit =
    */core/*
    dbldatagen/core/*
    dbldatagen/core/**

[report]
exclude_lines =
    if self.debug:
    pragma: no cover
    raise NotImplementedError
    if __name__ == .__main__.:

ignore_errors = True
omit =
    tests/*
    examples/*
    tutorial/*
    setup.py
    */core/*
    dbldatagen/core/*
    dbldatagen/core/**
