{
  "tables": [
    {
      "name": "regions",
      "rows": 10,
      "primary_key": { "columns": ["region_id"] },
      "columns": [
        {
          "name": "region_id",
          "gen": { "strategy": "sequence", "start": 1, "step": 1 }
        },
        {
          "name": "region_name",
          "dtype": "string",
          "gen": {
            "strategy": "values",
            "values": ["North", "South", "East", "West", "Central",
                       "NorthEast", "NorthWest", "SouthEast", "SouthWest", "Pacific"]
          }
        }
      ]
    },
    {
      "name": "customers",
      "rows": 500,
      "primary_key": { "columns": ["customer_id"] },
      "columns": [
        {
          "name": "customer_id",
          "gen": { "strategy": "pattern", "template": "CUST-{digit:6}" }
        },
        {
          "name": "region_id",
          "gen": { "strategy": "constant", "value": null },
          "foreign_key": {
            "ref": "regions.region_id",
            "distribution": { "type": "zipf", "exponent": 1.3 }
          }
        },
        {
          "name": "tier",
          "dtype": "string",
          "gen": {
            "strategy": "values",
            "values": ["bronze", "silver", "gold", "platinum"],
            "distribution": {
              "type": "weighted",
              "weights": { "bronze": 0.5, "silver": 0.3, "gold": 0.15, "platinum": 0.05 }
            }
          }
        }
      ]
    },
    {
      "name": "products",
      "rows": 100,
      "primary_key": { "columns": ["product_id"] },
      "columns": [
        {
          "name": "product_id",
          "gen": { "strategy": "uuid" }
        },
        {
          "name": "price",
          "dtype": "double",
          "gen": { "strategy": "range", "min": 1.0, "max": 999.99 }
        }
      ]
    },
    {
      "name": "orders",
      "rows": 5000,
      "primary_key": { "columns": ["order_id"] },
      "columns": [
        {
          "name": "order_id",
          "gen": { "strategy": "sequence", "start": 1, "step": 1 }
        },
        {
          "name": "customer_id",
          "gen": { "strategy": "constant", "value": null },
          "foreign_key": {
            "ref": "customers.customer_id",
            "distribution": { "type": "zipf", "exponent": 1.5 }
          }
        },
        {
          "name": "order_date",
          "gen": { "strategy": "timestamp", "start": "2023-01-01", "end": "2024-12-31" }
        }
      ]
    },
    {
      "name": "order_items",
      "rows": 15000,
      "primary_key": { "columns": ["item_id"] },
      "columns": [
        {
          "name": "item_id",
          "gen": { "strategy": "sequence", "start": 1, "step": 1 }
        },
        {
          "name": "order_id",
          "gen": { "strategy": "constant", "value": null },
          "foreign_key": {
            "ref": "orders.order_id",
            "distribution": { "type": "uniform" }
          }
        },
        {
          "name": "product_id",
          "gen": { "strategy": "constant", "value": null },
          "foreign_key": {
            "ref": "products.product_id",
            "distribution": { "type": "zipf", "exponent": 1.8 }
          }
        },
        {
          "name": "quantity",
          "dtype": "int",
          "gen": { "strategy": "range", "min": 1, "max": 10 }
        }
      ]
    },
    {
      "name": "reviews",
      "rows": 3000,
      "columns": [
        {
          "name": "review_id",
          "gen": { "strategy": "sequence", "start": 1, "step": 1 }
        },
        {
          "name": "customer_id",
          "gen": { "strategy": "constant", "value": null },
          "foreign_key": {
            "ref": "customers.customer_id",
            "nullable": true,
            "null_fraction": 0.2
          }
        },
        {
          "name": "product_id",
          "gen": { "strategy": "constant", "value": null },
          "foreign_key": {
            "ref": "products.product_id"
          }
        },
        {
          "name": "rating",
          "dtype": "int",
          "gen": { "strategy": "range", "min": 1, "max": 5 }
        }
      ]
    }
  ],
  "seed": 77
}
